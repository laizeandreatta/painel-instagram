# =========================================================================
# Copie este arquivo para ".env.local" e preencha os valores.
# Sem isso, o painel roda em "modo demonstração" com dados fictícios.
# Veja o passo a passo completo no README.md
# =========================================================================

# Painel do Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Painel do Supabase > Project Settings > API > service_role (NUNCA compartilhe essa chave)
# Usada só nas rotas de servidor (/api/instagram/sync)
SUPABASE_SERVICE_ROLE_KEY=

# Meta for Developers > seu App > Instagram Graph API
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# Senha que você inventa para proteger a rota de sincronização automática
CRON_SECRET=

# Hubla > Integrações > Webhook > Aba Autenticação > "Hubla Webhook Token"
# Usada pela rota /api/hubla/webhook para confirmar que a venda veio da Hubla
HUBLA_WEBHOOK_TOKEN=

# Opcional: só preencha se quiser trocar o produto/oferta que alimenta o
# CRM Assessoria. Por padrão já usa o produto da consultoria (Valore).
HUBLA_PRODUTO_ID=

# WhatsApp Business Platform (Meta) > número comercial > token permanente.
# Usadas para ENVIAR (não só receber) o WhatsApp com o link de agendamento
# assim que uma venda é confirmada na Hubla. Veja o passo a passo no README.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Opcional: nome do modelo de mensagem aprovado no WhatsApp Manager que
# contém o link de agendamento. Por padrão usa "agendamento_consultoria".
WHATSAPP_TEMPLATE_AGENDAMENTO=

# Google Cloud Console > seu projeto > Credenciais > IDs do cliente OAuth 2.0
# Usadas pela rota /api/calendar/sync para conferir na sua agenda do Google
# se a pessoa marcou a consultoria. Veja o passo a passo no README.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Obtido uma única vez acessando /api/admin/google/auth?secret=SEU_CRON_SECRET
# (veja o README) — não preencha isso à mão.
GOOGLE_REFRESH_TOKEN=

# Opcional: qual agenda do Google conferir. Por padrão usa "primary" (a
# agenda principal da conta que autorizou em /api/admin/google/auth).
GOOGLE_CALENDAR_ID=
